{
  "name": "@gigaverse/tokens",
  "version": "0.1.0",
  "description": "Gigaverse design tokens — colors, typography, motion, gradients, and Tailwind preset.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind": {
      "types": "./dist/tailwind.preset.d.ts",
      "import": "./dist/tailwind.preset.js",
      "require": "./dist/tailwind.preset.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2",
    "tailwindcss": "^3.4.17"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": { "optional": true }
  }
}
